PORT=3001
API_BASE_URL=https://api.gravvia.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://wyhvhfdeviuvsvgxovnq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Ind5aHZoZmRldml1dnN2Z3hvdm5xIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTcyMjA5NSwiZXhwIjoyMDk3Mjk4MDk1fQ.roKOHnGreObf_9Txu02M9Q3nksJEBw-FSSoYOifp5Fk
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Ind5aHZoZmRldml1dnN2Z3hvdm5xIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3MjIwOTUsImV4cCI6MjA5NzI5ODA5NX0.uXd_f9PooZ5z5Z7550PCFqD2u2BQVNdLYsHHmYddzZw
DATABASE_URL=postgresql://postgres:3E2zB4fZlhSI6oTf@db.wyhvhfdeviuvsvgxovnq.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Retell AI
RETELL_API_KEY=your-retell-api-key
# Retell signs webhooks AND custom-function calls with the API KEY above
# (X-Retell-Signature: v={ts},d={digest}). There is NO separate webhook secret
# to set in the Retell dashboard. RETELL_WEBHOOK_SECRET is optional/legacy.
RETELL_WEBHOOK_SECRET=
# Default Retell voice id for provisioned agents (override per-client in settings).
RETELL_DEFAULT_VOICE_ID=11labs-Adrian
# Base URL Retell calls back into (events + custom functions). Falls back to
# API_BASE_URL when unset. Must be publicly reachable (e.g. your Render URL).
WEBHOOK_BASE_URL=https://api.gravvia.com

# Encryption (for CRM credentials at rest)
ENCRYPTION_KEY=32-byte-hex-string-for-aes-256-gcm

# GoHighLevel (default / global – per-client stored in DB)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# HubSpot
HUBSPOT_APP_ID=
HUBSPOT_CLIENT_SECRET=

# Salesforce
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=

# Zoho
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.gravvia.com/oauth/google/callback

# Microsoft / Outlook
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://api.gravvia.com/oauth/microsoft/callback

# Calendly
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Email / Notifications
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@gravvia.com

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# BullMQ
BULL_DASHBOARD_PORT=3002

# Sentry (optional)
SENTRY_DSN=
