# Build context is the repo root — keep it small and never ship secrets/artifacts.
**/node_modules
**/dist
**/.next
**/coverage

# Secrets / local env (env is injected via docker-compose env_file at runtime)
.env
**/.env
**/.env.local
*.log

# VCS / editor / OS
.git
.gitignore
**/.DS_Store
.vscode
.idea

# Docker / CI meta (not needed inside images)
docker-compose.yml
**/Dockerfile
**/Dockerfile.*
**/.dockerignore
