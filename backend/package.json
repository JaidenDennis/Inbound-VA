{
  "name": "@gravvia/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "routing:enable": "tsx scripts/enable-inbound-routing.ts",
    "verify:ghl": "tsx scripts/ghl-live-verify.ts",
    "smoke:ghl": "tsx scripts/ghl-smoke-test.ts",
    "connect:ghl": "tsx scripts/ghl-connect-pit.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@sentry/node": "^10.59.0",
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.17.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.3.0",
    "retell-sdk": "^5.38.0",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.12.0",
    "pg": "^8.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
